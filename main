    <div id="passwordOverlay" style="position:fixed;inset:0;background:#000;z-index:99999;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:1.5rem;">
        <h1 style="color:#fff;font-size:2.5rem;font-weight:800;letter-spacing:-0.02em;">Moon v3</h1>
        <div style="display:flex;flex-direction:column;align-items:center;gap:1rem;">
            <input type="password" id="passwordInput" placeholder="Enter password..." style="padding:1rem 1.5rem;font-size:16px;border:2px solid #333;border-radius:12px;background:#111;color:#fff;outline:none;width:280px;text-align:center;transition:all 0.3s;" onkeydown="if(event.key==='Enter')checkPassword()">
            <button onclick="checkPassword()" style="padding:0.875rem 2rem;font-size:16px;font-weight:600;border:0;border-radius:12px;background:#fff;color:#000;cursor:pointer;transition:all 0.3s;min-width:280px;" onmouseover="this.style.background='#ccc'" onmouseout="this.style.background='#fff'">Enter</button>
            <p id="passwordError" style="color:#ff4444;font-size:14px;margin:0;opacity:0;transition:opacity 0.3s;">Incorrect password</p>
        </div>
    </div>
    <script>
        function checkPassword() {
            const input = document.getElementById('passwordInput').value;
            const error = document.getElementById('passwordError');
            if (input === '0000') {
                document.getElementById('passwordOverlay').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('passwordOverlay').style.display = 'none';
                }, 500);
            } else {
                error.style.opacity = '1';
                document.getElementById('passwordInput').style.borderColor = '#ff4444';
                setTimeout(() => {
                    error.style.opacity = '0';
                    document.getElementById('passwordInput').style.borderColor = '#333';
                }, 2000);
            }
        }
    </script>

    <div id="loadingScreen" style="position:fixed;inset:0;background:#000;z-index:99998;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2rem;transition:opacity 0.6s ease;">
        <div style="display:flex;flex-direction:column;align-items:center;gap:0.5rem;">
            <img src="data:image/png;base64," style="width:80px;height:80px;border-radius:50%;object-fit:cover;animation:pulse 2s ease-in-out infinite;" alt="Moon">
            <span style="color:#fff;font-size:1.5rem;font-weight:800;letter-spacing:-0.02em;">Moon v3</span>
        </div>
        <div style="width:280px;height:4px;background:#222;border-radius:2px;overflow:hidden;">
            <div id="loadingBar" style="width:0%;height:100%;background:#fff;border-radius:2px;transition:width 0.3s ease;"></div>
        </div>
        <div id="loadingText" style="color:#666;font-size:13px;font-weight:500;">Initializing...</div>
        <style>
            @keyframes pulse {
                0%, 100% { transform: scale(1); opacity: 1; }
                50% { transform: scale(1.05); opacity: 0.8; }
            }
        </style>
    </div>
    <script>
        (function() {
            const steps = [
                { pct: 15, text: 'Loading assets...' },
                { pct: 35, text: 'Fetching zones...' },
                { pct: 55, text: 'Building grid...' },
                { pct: 75, text: 'Applying theme...' },
                { pct: 90, text: 'Finalizing...' },
                { pct: 100, text: 'Ready!' }
            ];
            let i = 0;
            function nextStep() {
                if (i >= steps.length) {
                    setTimeout(() => {
                        document.getElementById('loadingScreen').style.opacity = '0';
                        setTimeout(() => {
                            document.getElementById('loadingScreen').style.display = 'none';
                        }, 1000);
                    }, 300);
                    return;
                }
                document.getElementById('loadingBar').style.width = steps[i].pct + '%';
                document.getElementById('loadingText').textContent = steps[i].text;
                i++;
                setTimeout(nextStep, 400 + Math.random() * 300);
            }
            nextStep();
        })();
    </script>





