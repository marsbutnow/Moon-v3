// Auto-collapse header after 20 seconds
let headerCollapsed = false;
let collapseTimer = null;

function startCollapseTimer() {
    if (collapseTimer) clearTimeout(collapseTimer);
    collapseTimer = setTimeout(() => {
        collapseHeader();
    }, 20000);
}

function collapseHeader() {
    const wrapper = document.getElementById('headerWrapper');
    const reveal = document.getElementById('headerReveal');
    if (wrapper && reveal) {
        wrapper.style.transform = 'translateY(-100%)';
        reveal.style.opacity = '1';
        reveal.style.pointerEvents = 'auto';
        headerCollapsed = true;
    }
}

function expandHeader() {
    const wrapper = document.getElementById('headerWrapper');
    const reveal = document.getElementById('headerReveal');
    if (wrapper && reveal) {
        wrapper.style.transform = 'translateY(0)';
        reveal.style.opacity = '0';
        reveal.style.pointerEvents = 'none';
        headerCollapsed = false;
        startCollapseTimer();
    }
}

// Reset timer on user activity
document.addEventListener('mousemove', () => {
    if (!headerCollapsed) startCollapseTimer();
});
document.addEventListener('click', () => {
    if (!headerCollapsed) startCollapseTimer();
});
document.addEventListener('keydown', () => {
    if (!headerCollapsed) startCollapseTimer();
});

// Start timer when page loads
document.addEventListener('DOMContentLoaded', startCollapseTimer);



